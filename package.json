{
  "name": "citrus-survey-rn",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:dev-client": "expo start --dev-client --port 8082",
    "ios:test": "expo run:ios --device \"KMG_iPhone17\" --port 8082",
    "lint": "eslint . --ext .ts,.tsx,.js",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "prebuild": "expo prebuild --clean",
    "pod:install": "cd ios && pod install",
    "ios:archive": "xcodebuild -workspace ios/app.xcworkspace -scheme app -configuration Release -archivePath ios/build/CitrusSurvey.xcarchive DEVELOPMENT_TEAM=X473XNY2W5 PRODUCT_BUNDLE_IDENTIFIER=com.citrussurvey.app archive",
    "ios:export": "xcodebuild -exportArchive -archivePath ios/build/CitrusSurvey.xcarchive -exportPath ios/export/output -exportOptionsPlist ios/export/ExportOptions.plist",
    "ios:release": "npm run ios:archive && npm run ios:export"
  },
  "dependencies": {
    "@react-native-community/netinfo": "11.4.1",
    "@react-native/virtualized-lists": "^0.81.5",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-av": "~16.0.8",
    "expo-file-system": "~19.0.21",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "~1.11.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tts": "^4.1.1",
    "uuid": "^13.0.0",
    "whisper.rn": "^0.5.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.85.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "^55.0.16",
    "eslint": "^8.57.1",
    "jest": "^30.3.0",
    "jest-expo": "~54.0.13",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
